            color3f inputs:in9.connect = </Looks/ocio_color_management_Standard_Surface1/switch10.outputs:out>
            color3f inputs:in10.connect = </Looks/ocio_color_management_Standard_Surface1/switch11.outputs:out>
            float inputs:which.connect = </Looks/ocio_color_management_Standard_Surface1/multiply1.outputs:out>
            token outputs:out
        }

        def Shader "texcoord1"
        {
            uniform token info:id = "ND_texcoord_vector2"
            token outputs:out
        }

        def Shader "separate2_1"
        {
            uniform token info:id = "ND_separate2_vector2"
            float2 inputs:in.connect = </Looks/ocio_color_management_Standard_Surface1/texcoord1.outputs:out>
            token outputs:out
        }

        def Shader "multiply1"
        {
            uniform token info:id = "ND_multiply_float"
            float inputs:in2 = 5
            float inputs:in1.connect = </Looks/ocio_color_management_Standard_Surface1/add1.outputs:out>
            token outputs:out
        }

        def Shader "position1"
        {
            uniform token info:id = "ND_position_vector3"

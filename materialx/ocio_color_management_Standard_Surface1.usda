#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    renderSettingsPrimPath = "/Render/Settings"
    subLayers = [
        @./base.usda@
    ]
    upAxis = "Y"
)


over "World"
{
    over "Sphere" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        rel material:binding = </Looks/ocio_color_management_Standard_Surface1>
    }
}

def Scope "Looks"
{
    def Material "ocio_color_management_Standard_Surface1"
    {
        token outputs:mtlx:surface.connect = </Looks/ocio_color_management_Standard_Surface1/standard_surface1.outputs:out>
        token outputs:surface.connect = </Looks/ocio_color_management_Standard_Surface1/standard_surface1.outputs:out>

        def Shader "standard_surface1"
        {
            uniform token info:id = "ND_standard_surface_surfaceshader"
            color3f inputs:base_color.connect = </Looks/ocio_color_management_Standard_Surface1/switch1.outputs:out>
            token outputs:out
        }


        def Shader "switch1"
        {
            uniform token info:id = "ND_switch_color3"
            color3f inputs:in1.connect = </Looks/ocio_color_management_Standard_Surface1/switch2.outputs:out>
            color3f inputs:in2.connect = </Looks/ocio_color_management_Standard_Surface1/switch3.outputs:out>
            color3f inputs:in3.connect = </Looks/ocio_color_management_Standard_Surface1/switch4.outputs:out>
            color3f inputs:in4.connect = </Looks/ocio_color_management_Standard_Surface1/switch5.outputs:out>

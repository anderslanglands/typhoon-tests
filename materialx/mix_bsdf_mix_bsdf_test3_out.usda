#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    renderSettingsPrimPath = "/Render/Settings"
    subLayers = [
        @./base.usda@
    ]
    upAxis = "Y"
)


over "World"
{
    over "Sphere" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        rel material:binding = </Looks/mix_bsdf_mix_bsdf_test3_out>
    }
}

def Scope "Looks"
{
    def Material "mix_bsdf_mix_bsdf_test3_out"
    {
        token outputs:mtlx:surface.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/mix_bsdf_test3.outputs:out>
        token outputs:surface.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/mix_bsdf_test3.outputs:out>

        def NodeGraph "mix_bsdf_test1"
        {
            token outputs:out.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/mix_bsdf_test1/surface1.outputs:out>

            def Shader "diffuse_brdf1"
            {
                uniform token info:id = "ND_oren_nayar_diffuse_bsdf"
                color3f inputs:color = (0.96, 0.1, 0.1)
                token outputs:out
            }
            def Shader "diffuse_brdf2"
            {
                uniform token info:id = "ND_oren_nayar_diffuse_bsdf"
                color3f inputs:color = (0.0, 0.73, 0.1)
                token outputs:out
            }
            def Shader "mix_bsdf1"
            {
                uniform token info:id = "ND_mix_bsdf"
                token inputs:fg.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/mix_bsdf_test1/diffuse_brdf1.outputs:out>
                token inputs:bg.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/mix_bsdf_test1/diffuse_brdf2.outputs:out>
                float inputs:mix = 0.5
                token outputs:out
            }
            def Shader "surface1"
            {
                uniform token info:id = "ND_surface"
                token inputs:bsdf.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/mix_bsdf_test1/mix_bsdf1.outputs:out>
                token outputs:out
            }
        }

        def NodeGraph "mix_bsdf_test2"
        {
            token outputs:out.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/mix_bsdf_test2/surface1.outputs:out>

            def Shader "diffuse_brdf1"
            {
                uniform token info:id = "ND_oren_nayar_diffuse_bsdf"
                color3f inputs:color = (0.96, 0.1, 0.1)
                float inputs:roughness = 0.0
                float3 inputs:normal = (0.0, 0.0, 0.0)
                token outputs:out
            }
            def Shader "dielectric_brdf1"
            {
                uniform token info:id = "ND_dielectric_bsdf"
                color3f inputs:tint = (1.0, 1.0, 1.0)
                float inputs:ior = 1.52
                token outputs:out
            }
            def Shader "mix_bsdf1"
            {
                uniform token info:id = "ND_mix_bsdf"
                token inputs:fg.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/mix_bsdf_test2/dielectric_brdf1.outputs:out>
                token inputs:bg.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/mix_bsdf_test2/diffuse_brdf1.outputs:out>
                float inputs:mix = 0.5
                token outputs:out
            }
            def Shader "surface1"
            {
                uniform token info:id = "ND_surface"
                token inputs:bsdf.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/mix_bsdf_test2/mix_bsdf1.outputs:out>
                token outputs:out
            }
        }

        def NodeGraph "IMP_substratebsdf"
        {
            color3f inputs:albedo = (0.8, 0.2, 0.1)
            color3f inputs:subsurface = (0.1, 0.1, 0.8)
            float inputs:subsurface_weight = 0.0
            token outputs:out.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/IMP_substratebsdf/mix1.outputs:out>

            def Shader "diffuse"
            {
                uniform token info:id = "ND_oren_nayar_diffuse_bsdf"
                color3f inputs:color.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/IMP_substratebsdf.inputs:albedo>
                token outputs:out
            }
            def Shader "subsurface2"
            {
                uniform token info:id = "ND_translucent_bsdf"
                color3f inputs:color.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/IMP_substratebsdf.inputs:subsurface>
                token outputs:out
            }
            def Shader "mix1"
            {
                uniform token info:id = "ND_mix_bsdf"
                token inputs:fg.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/IMP_substratebsdf/diffuse.outputs:out>
                token inputs:bg.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/IMP_substratebsdf/subsurface2.outputs:out>
                float inputs:mix.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/IMP_substratebsdf.inputs:subsurface_weight>
                token outputs:out
            }
        }

        def NodeGraph "IMP_substrateshader"
        {
            color3f inputs:albedo = (0.8, 0.2, 0.1)
            color3f inputs:subsurface = (0.1, 0.1, 0.8)
            float inputs:subsurface_weight = 0.0
            color3f inputs:emission = (0.0, 0.0, 0.0)
            float inputs:opacity = 1.0
            token outputs:out.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/IMP_substrateshader/surface1.outputs:out>

            def Shader "substrate1"
            {
                uniform token info:id = "ND_substratebsdf"
                color3f inputs:albedo.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/IMP_substrateshader.inputs:albedo>
                color3f inputs:subsurface.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/IMP_substrateshader.inputs:subsurface>
                float inputs:subsurface_weight.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/IMP_substrateshader.inputs:subsurface_weight>
                token outputs:out
            }
            def Shader "edf1"
            {
                uniform token info:id = "ND_uniform_edf"
                color3f inputs:color.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/IMP_substrateshader.inputs:emission>
                token outputs:out
            }
            def Shader "surface1"
            {
                uniform token info:id = "ND_surface"
                token inputs:bsdf.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/IMP_substrateshader/substrate1.outputs:out>
                token inputs:edf.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/IMP_substrateshader/edf1.outputs:out>
                float inputs:opacity.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/IMP_substrateshader.inputs:opacity>
                token outputs:out
            }
        }

        def NodeGraph "mix_bsdf_test3"
        {
            token outputs:out.connect = </Looks/mix_bsdf_mix_bsdf_test3_out/mix_bsdf_test3/shader1.outputs:out>

            def Shader "shader1"
            {
                uniform token info:id = "ND_substrateshader"
                token outputs:out
            }
        }

    }
}

over "Render"
{
    over "Settings"
    {
        over "Product"
        {
            token productName = "materialx.mix_bsdf_mix_bsdf_test3_out.exr"
        }
    }
}

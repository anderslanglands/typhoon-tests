#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    renderSettingsPrimPath = "/Render/Settings"
    subLayers = [
        @./base.usda@
    ]
    upAxis = "Y"
)


over "World"
{
    over "Sphere" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        rel material:binding = </Looks/thin_film_bsdf_thin_film_test6_out>
    }
}

def Scope "Looks"
{
    def Material "thin_film_bsdf_thin_film_test6_out"
    {
        token outputs:mtlx:surface.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test6.outputs:out>
        token outputs:surface.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test6.outputs:out>

        def NodeGraph "thin_film_test1"
        {
            token outputs:out.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test1/surface1.outputs:out>

            def Shader "dielectric_brdf_1"
            {
                uniform token info:id = "ND_dielectric_bsdf"
                float inputs:ior = 2.5
                float2 inputs:roughness = (0, 0)
                float inputs:thinfilm_thickness = 550
                float inputs:thinfilm_ior = 1.5
                token outputs:out
            }
            def Shader "surface1"
            {
                uniform token info:id = "ND_surface"
                token inputs:bsdf.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test1/dielectric_brdf_1.outputs:out>
                token outputs:out
            }
        }

        def NodeGraph "thin_film_test2"
        {
            token outputs:out.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test2/surface1.outputs:out>

            def Shader "diffuse_bsdf"
            {
                uniform token info:id = "ND_oren_nayar_diffuse_bsdf"
                float inputs:weight = 0.5
                color3f inputs:color = (1, 1, 1)
                token outputs:out
            }
            def Shader "dielectric_brdf_1"
            {
                uniform token info:id = "ND_dielectric_bsdf"
                float inputs:ior = 2.5
                float2 inputs:roughness = (0, 0)
                float inputs:thinfilm_thickness = 550
                float inputs:thinfilm_ior = 1.5
                token outputs:out
            }
            def Shader "layer_bsdf_1"
            {
                uniform token info:id = "ND_layer_bsdf"
                token inputs:top.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test2/dielectric_brdf_1.outputs:out>
                token inputs:base.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test2/diffuse_bsdf.outputs:out>
                token outputs:out
            }
            def Shader "surface1"
            {
                uniform token info:id = "ND_surface"
                token inputs:bsdf.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test2/layer_bsdf_1.outputs:out>
                token outputs:out
            }
        }

        def NodeGraph "thin_film_test3"
        {
            token outputs:out.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test3/surface1.outputs:out>

            def Shader "dielectric_brdf_1"
            {
                uniform token info:id = "ND_dielectric_bsdf"
                float inputs:ior = 2.5

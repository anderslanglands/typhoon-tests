            token outputs:out.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test7/surface1.outputs:out>

            def Shader "conductor_brdf_1"
            {
                uniform token info:id = "ND_conductor_bsdf"
                color3f inputs:ior = (0.18, 0.42, 1.37)
                color3f inputs:extinction = (3.42, 2.35, 1.77)
                float2 inputs:roughness = (0.0, 0.0)
                float inputs:thinfilm_thickness = 550

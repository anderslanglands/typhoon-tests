                token inputs:in1.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test6/dielectric_brdf_1.outputs:out>
                float inputs:in2 = 0.8
                token outputs:out
            }
            def Shader "surface1"
            {
                uniform token info:id = "ND_surface"
                token inputs:bsdf.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test6/multiply_bsdf_1.outputs:out>
                token outputs:out

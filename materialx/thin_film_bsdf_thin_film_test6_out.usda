            def Shader "mix_bsdf_1"
            {
                uniform token info:id = "ND_mix_bsdf"
                token inputs:fg.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test5/dielectric_brdf_2.outputs:out>
                token inputs:bg.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test5/dielectric_brdf_1.outputs:out>

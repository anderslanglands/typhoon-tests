                token inputs:base.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test3/diffuse_bsdf.outputs:out>
                token outputs:out
            }
            def Shader "surface1"
            {
                uniform token info:id = "ND_surface"
                token inputs:bsdf.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test3/layer_bsdf_2.outputs:out>
                token outputs:out
            }
        }

        def NodeGraph "thin_film_test4"
        {
            token outputs:out.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test4/surface1.outputs:out>


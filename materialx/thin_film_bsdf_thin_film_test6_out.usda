            {
                uniform token info:id = "ND_layer_bsdf"
                token inputs:top.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test4/dielectric_brdf_2.outputs:out>
                token inputs:base.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test4/dielectric_brdf_1.outputs:out>
                token outputs:out

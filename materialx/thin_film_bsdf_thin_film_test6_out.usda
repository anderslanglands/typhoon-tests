        def NodeGraph "thin_film_test5"
        {
            token outputs:out.connect = </Looks/thin_film_bsdf_thin_film_test6_out/thin_film_test5/surface1.outputs:out>

            def Shader "dielectric_brdf_1"
            {
                uniform token info:id = "ND_dielectric_bsdf"
                color3f inputs:tint = (1.0, 0.0, 0.0)
                float inputs:ior = 1.5
                float2 inputs:roughness = (0.3, 0.3)
                float inputs:thinfilm_thickness = 550
                float inputs:thinfilm_ior = 1.5

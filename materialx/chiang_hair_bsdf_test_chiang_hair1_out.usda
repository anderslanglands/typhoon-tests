#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    renderSettingsPrimPath = "/Render/Settings"
    subLayers = [
        @./base.usda@
    ]
    upAxis = "Y"
)


over "World"
{
    over "Sphere" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        rel material:binding = </Looks/chiang_hair_bsdf_test_chiang_hair1_out>
    }
}

def Scope "Looks"
{
    def Material "chiang_hair_bsdf_test_chiang_hair1_out"
    {
        token outputs:mtlx:surface.connect = </Looks/chiang_hair_bsdf_test_chiang_hair1_out/test_chiang_hair1.outputs:out>
        token outputs:surface.connect = </Looks/chiang_hair_bsdf_test_chiang_hair1_out/test_chiang_hair1.outputs:out>

        def NodeGraph "test_chiang_hair1"
        {
            token outputs:out.connect = </Looks/chiang_hair_bsdf_test_chiang_hair1_out/test_chiang_hair1/surface1.outputs:out>

            def Shader "chiang_hair_bsdf1"
            {
                uniform token info:id = "ND_chiang_hair_bsdf"
                float inputs:ior = 1.5
                color3f inputs:tint_R = (0.9, 0.8, 0.7)
                color3f inputs:tint_TT = (1.0, 0.9, 0.7)
                color3f inputs:tint_TRT = (0.5, 0.5, 1.0)
                float2 inputs:roughness_R = (0.1, 0.2)
                float2 inputs:roughness_TT = (0.05, 0.07)
                float2 inputs:roughness_TRT = (0.2, 0.4)
                float inputs:cuticle_angle = 0.6
                float3 inputs:absorption_coefficient = (0.2, 0.5, 0.8)
                token outputs:out
            }
            def Shader "surface1"
            {
                uniform token info:id = "ND_surface"
                token inputs:bsdf.connect = </Looks/chiang_hair_bsdf_test_chiang_hair1_out/test_chiang_hair1/chiang_hair_bsdf1.outputs:out>
                float inputs:opacity = 1.0
                token outputs:out
            }
        }

    }
}

over "Render"
{
    over "Settings"
    {
        over "Product"
        {
            token productName = "materialx.chiang_hair_bsdf_test_chiang_hair1_out.exr"
        }
    }
}

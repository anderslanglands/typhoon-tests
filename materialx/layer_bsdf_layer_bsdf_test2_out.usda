#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    renderSettingsPrimPath = "/Render/Settings"
    subLayers = [
        @./base.usda@
    ]
    upAxis = "Y"
)


over "World"
{
    over "Sphere" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        rel material:binding = </Looks/layer_bsdf_layer_bsdf_test2_out>
    }
}

def Scope "Looks"
{
    def Material "layer_bsdf_layer_bsdf_test2_out"
    {
        token outputs:mtlx:surface.connect = </Looks/layer_bsdf_layer_bsdf_test2_out/layer_bsdf_test2.outputs:out>
        token outputs:surface.connect = </Looks/layer_bsdf_layer_bsdf_test2_out/layer_bsdf_test2.outputs:out>

        def NodeGraph "layer_bsdf_test1"
        {
            token outputs:out.connect = </Looks/layer_bsdf_layer_bsdf_test2_out/layer_bsdf_test1/surface1.outputs:out>

            def Shader "diffuse_brdf_1"
            {
                uniform token info:id = "ND_oren_nayar_diffuse_bsdf"
                token outputs:out
            }
            def Shader "sheen_brdf_1"
            {
                uniform token info:id = "ND_sheen_bsdf"
                token outputs:out
            }
            def Shader "dielectric_brdf_1"
            {
                uniform token info:id = "ND_dielectric_bsdf"
                float inputs:ior = 2.5
                token outputs:out
            }
            def Shader "dielectric_brdf_2"
            {
                uniform token info:id = "ND_dielectric_bsdf"
                float inputs:ior = 1.2
                color3f inputs:tint = (1, 0, 0)
                token outputs:out
            }
            def Shader "layer_bsdf_1"
            {
                uniform token info:id = "ND_layer_bsdf"
                token inputs:top.connect = </Looks/layer_bsdf_layer_bsdf_test2_out/layer_bsdf_test1/dielectric_brdf_2.outputs:out>
                token inputs:base.connect = </Looks/layer_bsdf_layer_bsdf_test2_out/layer_bsdf_test1/dielectric_brdf_1.outputs:out>
                token outputs:out
            }
            def Shader "layer_bsdf_2"
            {
                uniform token info:id = "ND_layer_bsdf"
                token inputs:top.connect = </Looks/layer_bsdf_layer_bsdf_test2_out/layer_bsdf_test1/layer_bsdf_1.outputs:out>
                token inputs:base.connect = </Looks/layer_bsdf_layer_bsdf_test2_out/layer_bsdf_test1/sheen_brdf_1.outputs:out>
                token outputs:out
            }
            def Shader "layer_bsdf_3"
            {
                uniform token info:id = "ND_layer_bsdf"
                token inputs:top.connect = </Looks/layer_bsdf_layer_bsdf_test2_out/layer_bsdf_test1/layer_bsdf_2.outputs:out>
                token inputs:base.connect = </Looks/layer_bsdf_layer_bsdf_test2_out/layer_bsdf_test1/diffuse_brdf_1.outputs:out>
                token outputs:out
            }
            def Shader "surface1"
            {
                uniform token info:id = "ND_surface"
                token inputs:bsdf.connect = </Looks/layer_bsdf_layer_bsdf_test2_out/layer_bsdf_test1/layer_bsdf_3.outputs:out>
                token outputs:out
            }
        }

        def NodeGraph "layer_bsdf_test2"
        {
            token outputs:out.connect = </Looks/layer_bsdf_layer_bsdf_test2_out/layer_bsdf_test2/surface1.outputs:out>

            def Shader "dielectric_R"
            {
                uniform token info:id = "ND_dielectric_bsdf"
                float inputs:ior = 1.8
                string inputs:scatter_mode = "R"
                token outputs:out
            }
            def Shader "dielectric_T"
            {
                uniform token info:id = "ND_dielectric_bsdf"
                float inputs:ior = 1.5
                string inputs:scatter_mode = "T"
                token outputs:out
            }
            def Shader "dielectric_interior"
            {
                uniform token info:id = "ND_anisotropic_vdf"
                float3 inputs:absorption = (0.8, 0.8, 0.1)
                float3 inputs:scattering = (0.0, 0.0, 0.0)
                float inputs:anisotropy = 0.0
                token outputs:out
            }
            def Shader "dielectric_T_with_interior"
            {
                uniform token info:id = "ND_layer_vdf"
                token inputs:top.connect = </Looks/layer_bsdf_layer_bsdf_test2_out/layer_bsdf_test2/dielectric_T.outputs:out>
                token inputs:base.connect = </Looks/layer_bsdf_layer_bsdf_test2_out/layer_bsdf_test2/dielectric_interior.outputs:out>
                token outputs:out
            }
            def Shader "dielectric"
            {
                uniform token info:id = "ND_layer_bsdf"
                token inputs:top.connect = </Looks/layer_bsdf_layer_bsdf_test2_out/layer_bsdf_test2/dielectric_R.outputs:out>
                token inputs:base.connect = </Looks/layer_bsdf_layer_bsdf_test2_out/layer_bsdf_test2/dielectric_T_with_interior.outputs:out>
                token outputs:out
            }
            def Shader "surface1"
            {
                uniform token info:id = "ND_surface"
                token inputs:bsdf.connect = </Looks/layer_bsdf_layer_bsdf_test2_out/layer_bsdf_test2/dielectric.outputs:out>
                token outputs:out
            }
        }

    }
}

over "Render"
{
    over "Settings"
    {
        over "Product"
        {
            token productName = "materialx.layer_bsdf_layer_bsdf_test2_out.exr"
        }
    }
}
